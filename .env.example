# Varis Environment Configuration
# Copy to .env and fill in your values

# NCBI API key (optional — increases rate limit from 3 to 10 requests/sec)
NCBI_API_KEY=

# FoldX license path (required for ΔΔG calculation)
FOLDX_PATH=
FOLDX_ROTABASE=

# PyRosetta license (required for independent ΔΔG)
PYROSETTA_LICENSE=

# Database (for VarisDB platform, Phase 5)
DATABASE_URL=postgresql://varis:password@localhost:5432/varisdb

# Redis (for task queue, Phase 5)
REDIS_URL=redis://localhost:6379/0

# ClinVar submission API key (register at https://submit.ncbi.nlm.nih.gov/)
CLINVAR_API_KEY=  # Required for ClinVar submission (register at https://submit.ncbi.nlm.nih.gov/)

# Claude API (for self-evolution Loop 2 LLM reasoning)
ANTHROPIC_API_KEY=
